// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// *
/// * ===========================
/// * USER & AUTHENTICATION
/// * ===========================
model User {
  id               String  @id @default(cuid())
  name             String?
  email            String  @unique
  username         String?
  password         String?
  image            String?
  stripeCustomerId String?

  disputeCount Int?
  refundCount  Int?

  role UserRole @default(USER)

  isSystemUser Boolean @default(false)

  isBanned                 Boolean    @default(false)
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt
  emailVerified            DateTime?
  profileAvatarFileAssetId String?
  profileAvatarFileAsset   FileAsset? @relation("UserProfileAvatarAsset", fields: [profileAvatarFileAssetId], references: [id], onDelete: SetNull)

  verificationFailedAttempts Int @default(0)

  isDeleted           Boolean   @default(false)
  deletedAt           DateTime?
  scheduledDeletionAt DateTime?
  anonymizedAt        DateTime?
  purgedAt            DateTime?

  moderationStrikeCount    Int       @default(0)
  moderationRiskScore      Int       @default(0)
  moderationState          String    @default("CLEAR")
  moderationLastIncidentAt DateTime?
  softBlockedUntil         DateTime?

  disputesOpened   Dispute[] @relation("DisputeOpenedBy")
  disputesResolved Dispute[] @relation("DisputeResolvedBy")

  deliveryEvidencesUploaded DeliveryEvidence[] @relation("DeliveryEvidenceUploadedBy")

  Account                 Account[]
  addresses               Address[]
  agentProfile            AgentProfile?
  staffProfile            StaffProfile?
  cart                    Cart?
  agentConversations      Conversation[]         @relation("ConversationAgent")
  couponClaims            CouponClaim[]
  couponUsages            CouponUsage[]
  deliveries              Delivery[]             @relation("RiderDeliveries")
  Notification            Notification[]
  customerOrders          Order[]                @relation("CustomerOrders")
  checkoutGroups          CheckoutGroup[]
  sellerGroups            OrderSellerGroup[]     @relation("SellerGroupBySeller")
  referralsReceived       Referral?              @relation("Referred")
  referralsMade           Referral[]             @relation("Referrer")
  referralCode            ReferralCode?
  referralRewards         ReferralReward[]       @relation("ReferralRewardBeneficiary")
  Review                  Review[]
  riderProfile            RiderProfile?
  riderSchedules          RiderSchedule[]
  searchHistories         SearchHistory[]
  Session                 Session[]
  store                   Store?
  StoreFollower           StoreFollower[]
  StoreReview             StoreReview[]
  conversationMemberships ConversationMember[]
  transactions            Transaction[]
  userPreference          UserPreference?
  wallet                  Wallet?
  wishlist                Wishlist?
  verifications           Verification[]
  verificationDocuments   VerificationDocument[]
  disputeEvidences        DisputeEvidence[]
  disputeMessages         DisputeMessage[]
  auditLogsAsActor        AuditLog[]             @relation("AuditLogActor")
  uploadedFileAssets      FileAsset[]            @relation("UploadedFileAssets")

  moderatorIdentity   ModeratorIdentity?
  moderationIncidents ModerationIncident[] @relation("ModerationSubjectUser")
  strikeSnapshots     UserStrikeSnapshot[]

  moderatedProducts Product[] @relation("ProductModeratedBy")

  reportsSubmitted        UserReport[]             @relation("UserReportsSubmitted")
  reportsAgainst          UserReport[]             @relation("UserReportsAgainst")
  reportsReviewed         UserReport[]             @relation("UserReportsReviewedBy")
  emailVerificationTokens EmailVerificationToken[]

  @@index([profileAvatarFileAssetId])
}

model AuditLog {
  id               String   @id @default(cuid())
  actorId          String?
  actorRole        UserRole
  actionType       String   @db.VarChar(80)
  targetEntityType String   @db.VarChar(80)
  targetEntityId   String?  @db.VarChar(191)
  summary          String   @db.VarChar(255)
  metadata         Json?
  createdAt        DateTime @default(now())
  actor            User?    @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorId])
  @@index([actionType, createdAt])
  @@index([targetEntityType, createdAt])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model PasswordResetAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

model EmailVerificationToken {
  id            String    @id @default(cuid())
  userId        String
  email         String
  tokenHash     String    @unique
  expiresAt     DateTime
  consumedAt    DateTime?
  invalidatedAt DateTime?
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([tokenHash])
  @@index([userId, email, createdAt])
  @@index([userId, email, consumedAt, invalidatedAt, expiresAt])
}

/// *
/// * ===========================
/// * STORAGE
/// * ===========================
model FileAsset {
  id String @id @default(cuid())

  storageProvider FileStorageProvider
  bucket          String?
  storageKey      String              @unique
  url             String
  cdnUrl          String?

  originalFileName String?
  extension        String?
  mimeType         String?
  fileSize         Int?
  checksumSha256   String?

  category FileAssetCategory
  kind     FileAssetKind

  width       Int?
  height      Int?
  durationMs  Int?
  blurDataUrl String?
  altText     String?
  metadata    Json?

  status     FileAssetStatus @default(ACTIVE)
  isPublic   Boolean         @default(false)
  deletedAt  DateTime?
  orphanedAt DateTime?
  lastUsedAt DateTime?

  uploadedById String?
  uploadedBy   User?   @relation("UploadedFileAssets", fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  disputeEvidences         DisputeEvidence[]
  deliveryEvidences        DeliveryEvidence[]
  productImages            ProductImage[]
  verificationDocuments    VerificationDocument[] @relation("VerificationDocumentAsset")
  userProfileAvatarUsers   User[]                 @relation("UserProfileAvatarAsset")
  storeLogoStores          Store[]                @relation("StoreLogoAsset")
  storeBannerStores        Store[]                @relation("StoreBannerAsset")
  categoryIconCategories   Category[]             @relation("CategoryIconAsset")
  categoryBannerCategories Category[]             @relation("CategoryBannerAsset")
  heroBannerBackgrounds    HeroBanner[]           @relation("HeroBannerBackgroundAsset")
  heroBannerProducts       HeroBanner[]           @relation("HeroBannerProductAsset")
  siteConfigurationLogos   SiteConfiguration[]    @relation("SiteConfigurationLogoAsset")

  @@index([status])
  @@index([category])
  @@index([kind])
  @@index([uploadedById])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([orphanedAt])
}

/// *
/// * ===========================
/// * PRODUCTS & CATEGORIES
/// * ===========================
model Product {
  id          String  @id @default(cuid())
  name        String  @db.VarChar(120)
  description String
  brand       String?
  storeId     String
  categoryId  String
  isPublished Boolean @default(true)

  moderationStatus ProductModerationStatus?
  moderationReason String?
  moderatedAt      DateTime?
  moderatedById    String?
  moderatedBy      User?                    @relation("ProductModeratedBy", fields: [moderatedById], references: [id], onDelete: SetNull)

  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  brandId                String?
  discount               Float?
  defaultPrepTimeMinutes Int?
  specifications         String[]                   @default([])
  technicalDetails       Json                       @default("[]")
  sold                   Int                        @default(0)
  basePriceUSD           Float
  oldPriceUSD            Float?
  averageRating          Float                      @default(0)
  reviewCount            Int                        @default(0)
  foodDetails            Json?
  isFoodProduct          Boolean                    @default(false)
  cartItems              CartItem[]
  inventoryReservations  InventoryReservation[]
  orderItems             OrderItem[]
  Brand                  Brand?                     @relation(fields: [brandId], references: [id])
  category               Category                   @relation(fields: [categoryId], references: [id])
  store                  Store                      @relation(fields: [storeId], references: [id])
  images                 ProductImage[]
  variants               ProductVariant[]
  reviews                Review[]
  wishlistItems          WishlistItem[]
  conversations          Conversation[]
  featuredPlacements     FeaturedProductPlacement[]
  foodProductConfig      FoodProductConfig?
  foodOptionGroups       FoodOptionGroup[]

  @@index([storeId])
  @@index([categoryId])
  @@index([isPublished])
  @@index([isFoodProduct])
}

model ProductVariant {
  id                    String                 @id @default(cuid())
  productId             String
  sku                   String
  color                 String?
  size                  String?
  stock                 Int                    @default(0)
  discount              Float?
  oldPriceUSD           Float?
  priceUSD              Float
  cartItems             CartItem[]
  inventoryReservations InventoryReservation[]
  orderItems            OrderItem[]
  product               Product                @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, sku])
  @@index([sku])
  @@index([productId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  fileAssetId String
  fileAsset   FileAsset @relation(fields: [fileAssetId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([fileAssetId])
}

model Category {
  id                     String     @id @default(cuid())
  name                   String     @unique
  slug                   String     @unique
  parentId               String?
  iconImageFileAssetId   String?
  bannerImageFileAssetId String?
  color                  String?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  path                   String?
  parent                 Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children               Category[] @relation("CategoryHierarchy")
  products               Product[]
  iconImageFileAsset     FileAsset? @relation("CategoryIconAsset", fields: [iconImageFileAssetId], references: [id], onDelete: SetNull)
  bannerImageFileAsset   FileAsset? @relation("CategoryBannerAsset", fields: [bannerImageFileAssetId], references: [id], onDelete: SetNull)

  @@index([path])
  @@index([iconImageFileAssetId])
  @@index([bannerImageFileAssetId])
}

model FoodProductConfig {
  id        String  @id @default(cuid())
  productId String  @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  itemType      FoodItemType
  inventoryMode FoodInventoryMode @default(AVAILABILITY_ONLY)

  isAvailable Boolean @default(true)
  isSoldOut   Boolean @default(false)

  preparationTimeMinutes Int?
  dailyOrderLimit        Int?
  ordersTodayCount       Int  @default(0)

  availableFrom  String?
  availableUntil String?
  availableDays  String[] @default([])

  allowScheduledOrder  Boolean @default(false)
  allowSameDayPreorder Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FoodOptionGroup {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  name          String
  description   String?
  type          FoodOptionGroupType
  isRequired    Boolean             @default(false)
  minSelections Int                 @default(0)
  maxSelections Int?
  displayOrder  Int                 @default(0)
  isActive      Boolean             @default(true)

  options   FoodOption[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([productId, isActive])
}

model FoodOption {
  id      String          @id @default(cuid())
  groupId String
  group   FoodOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  name          String
  description   String?
  priceDeltaUSD Float   @default(0)
  isDefault     Boolean @default(false)
  isAvailable   Boolean @default(true)
  stock         Int?
  displayOrder  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId, isAvailable])
}

/// *
/// * ===========================
/// * REVIEWS & SEARCH
/// * ===========================
model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orderId   String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId, orderId])
}

model SearchHistory {
  id        String   @id @default(cuid())
  query     String
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([query])
  @@index([userId])
}

model SearchKeyword {
  id        String   @id @default(cuid())
  keyword   String   @unique
  count     Int      @default(1)
  updatedAt DateTime @updatedAt
}

/// *
/// * ===========================
/// * CART & WISHLIST
/// * ===========================
model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id                      String                   @id @default(cuid())
  cartId                  String
  productId               String
  variantId               String?
  selectionFingerprint    String                   @default("")
  quantity                Int                      @default(1)
  cart                    Cart                     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product                 Product                  @relation(fields: [productId], references: [id])
  variant                 ProductVariant?          @relation(fields: [variantId], references: [id])
  cartItemSelectedOptions CartItemSelectedOption[]

  @@unique([cartId, productId, variantId, selectionFingerprint])
  @@index([cartId])
  @@index([productId])
  @@index([variantId])
}

model CartItemSelectedOption {
  id         String   @id @default(cuid())
  cartItemId String
  cartItem   CartItem @relation(fields: [cartItemId], references: [id], onDelete: Cascade)

  optionGroupId String
  optionId      String

  optionGroupName String
  optionName      String
  priceDeltaUSD   Float

  createdAt DateTime @default(now())

  @@index([cartItemId])
}

model Wishlist {
  id        String         @id @default(cuid())
  userId    String         @unique
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WishlistItem[]
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId])
  @@index([wishlistId])
  @@index([productId])
}

/// *
/// * ===========================
/// * ORDERS
/// * ===========================
model Order {
  id                   String         @id @default(cuid())
  userId               String
  status               OrderStatus    @default(PENDING_PAYMENT)
  deliveryType         DeliveryType   @default(HOME_DELIVERY)
  shippingFee          Float          @default(0)
  totalAmount          Float
  distanceInMiles      Float          @default(0)
  isPaid               Boolean        @default(false)
  payoutReleased       Boolean        @default(false)
  isFoodOrder          Boolean        @default(false)
  estimatedDeliveryMin DateTime?
  estimatedDeliveryMax DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  paymentMethod        PaymentMethod?
  trackingNumber       String?        @unique
  couponId             String?
  discountAmount       Float?
  customerConfirmedAt  DateTime?
  deliveryPhone        String
  deliveryCity         String
  deliveryCountry      String
  deliveryFullName     String
  deliveryPostal       String
  deliveryState        String
  deliveryStreet       String

  stockDecrementedAt DateTime?

  postPaymentFinalized    Boolean                @default(false)
  arrivedAtHubConfirmedAt DateTime?
  arrivedAtHubConfirmedBy String?
  checkoutGroupId         String?
  couponUsages            CouponUsage[]
  delivery                Delivery?              @relation("OrderDelivery")
  checkoutGroup           CheckoutGroup?         @relation(fields: [checkoutGroupId], references: [id])
  coupon                  Coupon?                @relation(fields: [couponId], references: [id])
  customer                User                   @relation("CustomerOrders", fields: [userId], references: [id], onDelete: Cascade)
  inventoryReservations   InventoryReservation[]
  items                   OrderItem[]
  sellerGroups            OrderSellerGroup[]
  orderTimelines          OrderTimeline[]
  referrals               Referral[]
  transactions            Transaction[]
  dispute                 Dispute?
  deliveryEvidences       DeliveryEvidence[]
  storeReviews            StoreReview[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([couponId])
  @@index([checkoutGroupId])
}

model OrderTimeline {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  message   String?
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

/// *
/// * GROUPS SELLER ITEMS PER ORDER
model OrderSellerGroup {
  id                 String @id @default(cuid())
  orderId            String
  storeId            String
  sellerId           String
  subtotal           Float
  shippingFee        Float
  sellerRevenue      Float
  platformCommission Float  @default(0)

  payoutStatus              PayoutStatus               @default(PENDING)
  status                    SellerGroupStatus          @default(PENDING)
  expectedAtHub             DateTime?
  arrivedAtHub              DateTime?
  prepTimeMinutes           Int?
  readyAt                   DateTime?
  isLate                    Boolean                    @default(false)
  lateMarkedAt              DateTime?
  actualReadyAt             DateTime?
  verified                  Boolean                    @default(false)
  createdAt                 DateTime                   @default(now())
  cancelledAt               DateTime?
  cancelledBy               OrderCancelledBy?
  cancelReason              SellerCancellationReason?
  cancelNote                String?
  payoutEligibleAt          DateTime?
  payoutLocked              Boolean                    @default(false)
  payoutReleasedAt          DateTime?
  hubInboundCode            String                     @unique
  internalTrackingNumber    String                     @unique
  items                     OrderItem[]                @relation("GroupItems")
  inventoryReservations     InventoryReservation[]
  order                     Order                      @relation(fields: [orderId], references: [id])
  seller                    User                       @relation("SellerGroupBySeller", fields: [sellerId], references: [id], onDelete: Cascade)
  store                     Store                      @relation(fields: [storeId], references: [id])
  disputeSellerGroupImpacts DisputeSellerGroupImpact[]
  deliveryEvidences         DeliveryEvidence[]
  disputeEvidences          DisputeEvidence[]
  storeReviews              StoreReview[]

  @@index([sellerId])
  @@index([payoutReleasedAt])
  @@index([sellerId, payoutReleasedAt])
}

model OrderItem {
  id            String  @id @default(cuid())
  orderId       String
  sellerGroupId String?
  productId     String
  variantId     String?
  quantity      Int
  price         Float
  basePrice     Float?
  optionsPrice  Float?  @default(0)
  lineTotal     Float?

  inventoryReservation     InventoryReservation?
  order                    Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product                  Product                   @relation(fields: [productId], references: [id])
  sellerGroup              OrderSellerGroup?         @relation("GroupItems", fields: [sellerGroupId], references: [id])
  variant                  ProductVariant?           @relation(fields: [variantId], references: [id])
  orderItemSelectedOptions OrderItemSelectedOption[]

  @@index([sellerGroupId])
}

model InventoryReservation {
  id             String                     @id @default(cuid())
  orderId        String
  orderItemId    String                     @unique
  sellerGroupId  String?
  productId      String
  variantId      String
  quantity       Int
  status         InventoryReservationStatus @default(RESERVED)
  reservationKey String                     @unique
  releaseReason  InventoryReleaseReason?
  committedAt    DateTime?
  releasedAt     DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  order          Order                      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem      OrderItem                  @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  sellerGroup    OrderSellerGroup?          @relation(fields: [sellerGroupId], references: [id])
  product        Product                    @relation(fields: [productId], references: [id])
  variant        ProductVariant             @relation(fields: [variantId], references: [id])

  @@index([orderId, status])
  @@index([sellerGroupId, status])
  @@index([variantId, status])
  @@index([productId])
}

model CheckoutGroup {
  id        String   @id @default(cuid())
  userId    String
  total     Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([userId])
  @@index([createdAt])
}

model OrderItemSelectedOption {
  id          String    @id @default(cuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  optionGroupName String
  optionName      String
  priceDeltaUSD   Float

  createdAt DateTime @default(now())

  @@index([orderItemId])
}

/// *
/// * ===========================
/// * JOBS & CRON
/// * ===========================
model Job {
  id         String   @id @default(cuid())
  type       String
  payload    Json
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  attempts   Int      @default(0)
  lastError  String?
  maxRetries Int      @default(5)
  runAt      DateTime @default(now())

  @@index([status])
  @@index([type])
  @@index([runAt])
  @@index([status, type, runAt])
}

model CronLock {
  name     String   @id
  lockedAt DateTime
}

/// *
/// * ===========================
/// * PAYMENTS & FINANCE
/// * ===========================
model Wallet {
  id            String        @id @default(cuid())
  userId        String        @unique
  balance       Float         @default(0)
  totalEarnings Float         @default(0)
  pending       Float         @default(0)
  currency      String        @default("USD")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  status        WalletStatus  @default(INACTIVE)
  transactions  Transaction[]
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  withdrawals   Withdrawal[]
}

model Withdrawal {
  id          String           @id @default(cuid())
  walletId    String
  amount      Float
  method      String?
  accountInfo String?
  status      WithdrawalStatus @default(PENDING)
  processedAt DateTime?
  createdAt   DateTime         @default(now())
  wallet      Wallet           @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Transaction {
  id              String            @id @default(cuid())
  walletId        String?
  orderId         String?
  userId          String?
  type            TransactionType
  amount          Float
  reference       String?           @unique
  description     String?
  status          TransactionStatus @default(SUCCESS)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  referralRewards ReferralReward[]
  order           Order?            @relation(fields: [orderId], references: [id])
  user            User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet          Wallet?           @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model IdempotencyKey {
  key       String   @id
  userId    String
  orderId   String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model EscrowLedger {
  id              String          @id @default(uuid())
  orderId         String
  userId          String?
  role            EscrowRole
  entryType       EscrowEntryType
  amount          Float
  currency        String          @default("USD")
  status          EscrowStatus    @default(PENDING)
  reference       String?         @unique
  metadata        Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  withdrawnAmount Float           @default(0)

  @@index([orderId])
  @@index([userId])
  @@index([status])
}

model LedgerEntry {
  id          String          @id @default(cuid())
  orderId     String?
  userId      String?
  walletId    String?
  accountType AccountType?
  entryType   LedgerEntryType
  direction   LedgerDirection
  amount      Float
  reference   String?         @unique
  createdAt   DateTime        @default(now())

  @@index([orderId])
  @@index([userId])
  @@index([walletId])
}

model EscrowSnapshot {
  id        String   @id @default(cuid())
  totalHeld Float
  createdAt DateTime @default(now())
}

model WalletReconciliationLog {
  id              String   @id @default(cuid())
  walletId        String
  previousBalance Float
  ledgerBalance   Float
  fixed           Boolean
  createdAt       DateTime @default(now())

  @@index([walletId])
  @@index([createdAt])
}

/// *
/// * ===========================
/// * RiDER & DELIVERY
/// * ===========================
model RiderProfile {
  id                 String    @id @default(cuid())
  userId             String    @unique
  vehicleType        String
  plateNumber        String
  licenseNumber      String
  vehicleColor       String
  vehicleModel       String
  isVerified         Boolean   @default(false)
  verifiedAt         DateTime?
  verificationMethod String?
  isAvailable        Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  stripeAccountId    String?   @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RiderSchedule {
  id        String  @id @default(cuid())
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean @default(true)
  riderId   String
  rider     User    @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@unique([riderId, dayOfWeek])
}

model Delivery {
  id                String         @id @default(cuid())
  orderId           String         @unique
  riderId           String?
  status            DeliveryStatus @default(PENDING_ASSIGNMENT)
  deliveryAddress   String?
  distance          Float?
  fee               Float
  riderPayoutAmount Float          @default(0)
  assignedAt        DateTime?
  deliveredAt       DateTime?
  otpAttempts       Int            @default(0)
  otpExpiresAt      DateTime?
  otpHash           String?
  isLocked          Boolean        @default(false)
  lockedAt          DateTime?
  payoutEligibleAt  DateTime?
  payoutLocked      Boolean        @default(false)
  payoutReleasedAt  DateTime?

  evidenceRequiredAtCompletion Boolean   @default(false)
  hasDeliveryEvidence          Boolean   @default(false)
  lastEvidenceAt               DateTime?
  failedAttemptCount           Int       @default(0)
  handoffConfirmedAt           DateTime?

  order    Order              @relation("OrderDelivery", fields: [orderId], references: [id], onDelete: Cascade)
  rider    User?              @relation("RiderDeliveries", fields: [riderId], references: [id])
  evidence DeliveryEvidence[]

  @@index([orderId])
  @@index([riderId])
  @@index([status])
}

model DeliveryEvidence {
  id String @id @default(cuid())

  deliveryId String
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  sellerGroupId String?
  sellerGroup   OrderSellerGroup? @relation(fields: [sellerGroupId], references: [id])

  uploadedById String
  uploadedBy   User   @relation("DeliveryEvidenceUploadedBy", fields: [uploadedById], references: [id])

  kind        DeliveryEvidenceType
  fileAssetId String
  fileAsset   FileAsset            @relation(fields: [fileAssetId], references: [id], onDelete: Restrict)
  caption     String?
  metadata    Json?

  capturedAt DateTime?
  isInternal Boolean            @default(false)
  visibility EvidenceVisibility @default(ADMIN_ONLY)

  linkedDisputeId String?
  linkedDispute   Dispute? @relation("DisputeLinkedDeliveryEvidence", fields: [linkedDisputeId], references: [id])

  createdAt        DateTime          @default(now())
  disputeEvidences DisputeEvidence[]

  @@index([deliveryId])
  @@index([orderId])
  @@index([sellerGroupId])
  @@index([uploadedById])
  @@index([fileAssetId])
  @@index([linkedDisputeId])
  @@index([deliveryId, createdAt])
  @@index([orderId, createdAt])
  @@index([visibility, isInternal])
}

/// *
/// * ===========================
/// * DISPUTES & REFUNDS
/// * ===========================
model Dispute {
  id String @id @default(cuid())

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  openedById String
  openedBy   User   @relation("DisputeOpenedBy", fields: [openedById], references: [id])

  status      DisputeStatus @default(OPEN)
  reason      DisputeReason
  description String?

  refundAmount Float?
  resolution   DisputeResolution?

  resolvedById String?
  resolvedBy   User?   @relation("DisputeResolvedBy", fields: [resolvedById], references: [id])

  resolutionSummary             String?
  internalNotes                 String?
  openedAt                      DateTime  @default(now())
  resolvedAt                    DateTime?
  closedAt                      DateTime?
  lastMessageAt                 DateTime?
  evidenceRequired              Boolean   @default(false)
  deliveryEvidenceSnapshotTaken Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  evidence                  DisputeEvidence[]
  messages                  DisputeMessage[]
  returnRequest             ReturnRequest?
  disputeSellerGroupImpacts DisputeSellerGroupImpact[]
  linkedDeliveryEvidence    DeliveryEvidence[]         @relation("DisputeLinkedDeliveryEvidence")

  @@index([status])
  @@index([openedById])
  @@index([resolvedById])
}

model DisputeEvidence {
  id String @id @default(cuid())

  disputeId String
  dispute   Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  type        EvidenceType
  fileAssetId String
  fileAsset   FileAsset    @relation(fields: [fileAssetId], references: [id], onDelete: Restrict)
  caption     String?
  metadata    Json?

  isInternal Boolean            @default(false)
  visibility EvidenceVisibility @default(PARTIES_AND_ADMIN)

  sellerGroupId String?
  sellerGroup   OrderSellerGroup? @relation(fields: [sellerGroupId], references: [id])

  messageId String?
  message   DisputeMessage? @relation(fields: [messageId], references: [id])

  deliveryEvidenceId String?
  deliveryEvidence   DeliveryEvidence? @relation(fields: [deliveryEvidenceId], references: [id])

  createdAt DateTime @default(now())

  @@index([disputeId])
  @@index([uploadedById])
  @@index([fileAssetId])
  @@index([sellerGroupId])
  @@index([deliveryEvidenceId])
  @@index([messageId])
  @@index([visibility, isInternal])
  @@index([disputeId, createdAt])
}

model DisputeMessage {
  id String @id @default(cuid())

  disputeId String
  dispute   Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation(fields: [senderId], references: [id])

  message String

  isInternal  Boolean            @default(false)
  messageType DisputeMessageType @default(TEXT)

  createdAt DateTime @default(now())

  attachments DisputeEvidence[]

  @@index([disputeId])
  @@index([senderId])
  @@index([createdAt])
  @@index([isInternal, messageType])
}

model ReturnRequest {
  id String @id @default(cuid())

  disputeId String  @unique
  dispute   Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  trackingNumber String?
  carrier        String?

  status ReturnStatus @default(PENDING)

  shippedAt  DateTime?
  receivedAt DateTime?
  approvedAt DateTime?
  rejectedAt DateTime?

  returnLabelUrl     String?
  returnEvidenceNote String?
  inspectedAt        DateTime?
  inspectionSummary  String?
  receivedCondition  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DisputeSellerGroupImpact {
  id String @id @default(cuid())

  disputeId String
  dispute   Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  sellerGroupId String
  sellerGroup   OrderSellerGroup @relation(fields: [sellerGroupId], references: [id])

  refundAmount Float

  createdAt DateTime @default(now())

  @@index([sellerGroupId])
}

/// *
/// * ===========================
/// * STORE & BRAND
/// * ===========================
model Store {
  id                        String                   @id @default(cuid())
  userId                    String                   @unique
  name                      String
  slug                      String                   @unique
  logoFileAssetId           String?
  description               String?
  location                  String?
  address                   String?
  shippingRatePerMile       Float                    @default(0.8)
  latitude                  Float?
  longitude                 Float?
  isActive                  Boolean                  @default(false)
  isSuspended               Boolean                  @default(false)
  suspensionReason          String?
  suspendedAt               DateTime?
  isVerified                Boolean                  @default(false)
  verifiedAt                DateTime?
  verificationMethod        String?
  bannerImageFileAssetId    String?
  tagline                   String?
  averageRating             Float                    @default(0)
  reviewCount               Int                      @default(0)
  emailNotificationsEnabled Boolean                  @default(true)
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  type                      StoreType                @default(GENERAL)
  fulfillmentType           FulfillmentType          @default(PHYSICAL)
  deletedAt                 DateTime?
  isDeleted                 Boolean                  @default(false)
  stripeAccountId           String?                  @unique
  Brand                     Brand[]
  storeGroups               OrderSellerGroup[]
  products                  Product[]
  owner                     User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  logoFileAsset             FileAsset?               @relation("StoreLogoAsset", fields: [logoFileAssetId], references: [id], onDelete: SetNull)
  bannerImageFileAsset      FileAsset?               @relation("StoreBannerAsset", fields: [bannerImageFileAssetId], references: [id], onDelete: SetNull)
  StoreFollower             StoreFollower[]
  StoreReview               StoreReview[]
  conversations             Conversation[]
  featuredPlacements        FeaturedStorePlacement[]

  @@index([userId])
  @@index([slug])
  @@index([isActive])
  @@index([logoFileAssetId])
  @@index([bannerImageFileAssetId])
}

model StoreFollower {
  id        String   @id @default(cuid())
  storeId   String
  userId    String
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storeId, userId])
  @@index([storeId])
  @@index([userId])
  @@index([createdAt])
}

model StoreReview {
  id            String   @id @default(cuid())
  storeId       String
  userId        String
  orderId       String
  sellerGroupId String
  rating        Int
  title         String?
  comment       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store       Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  order       Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sellerGroup OrderSellerGroup @relation(fields: [sellerGroupId], references: [id], onDelete: Cascade)

  @@unique([sellerGroupId, userId])
  @@index([storeId, createdAt])
  @@index([userId, createdAt])
  @@index([orderId])
  @@index([sellerGroupId])
}

model Brand {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  storeId  String
  store    Store     @relation(fields: [storeId], references: [id])
  products Product[]
}

model ProductAnalytics {
  id        String @id @default(cuid())
  productId String @unique
  views     Int    @default(0)
  clicks    Int    @default(0)
  sales     Int    @default(0)
}

model StoreAnalytics {
  id      String @id @default(cuid())
  storeId String @unique
  views   Int    @default(0)
  clicks  Int    @default(0)
  sales   Int    @default(0)
}

/// *
/// * ===========================
/// * MESSAGE SYSTEM & CHAT
/// * ===========================
model Conversation {
  id            String               @id @default(cuid())
  userId        String
  orderId       String?
  storeId       String?
  productId     String?
  type          ConversationType
  status        ConversationStatus   @default(OPEN)
  subject       String?
  lastMessageAt DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  agentId       String?
  agent         User?                @relation("ConversationAgent", fields: [agentId], references: [id])
  store         Store?               @relation(fields: [storeId], references: [id])
  product       Product?             @relation(fields: [productId], references: [id])
  members       ConversationMember[]
  messages      Message[]

  @@index([userId, updatedAt])
  @@index([type, userId, storeId, productId])
  @@index([lastMessageAt])
}

model AgentProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String?
  senderType     SenderType
  content        String
  createdAt      DateTime     @default(now())
  readAt         DateTime?
  deliveredAt    DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId, createdAt])
}

model ConversationMember {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

/// *
/// * ===========================
/// * COUPONS & PROMOTIONS
/// * ===========================
model Coupon {
  id             String        @id @default(uuid())
  code           String        @unique
  type           CouponType
  value          Int
  minOrderAmount Int?
  maxDiscount    Int?
  usageLimit     Int?
  usedCount      Int           @default(0)
  isActive       Boolean       @default(true)
  appliesTo      CouponScope
  createdByAdmin Boolean       @default(false)
  createdAt      DateTime      @default(now())
  perUserLimit   Int?
  validFrom      DateTime?
  validTo        DateTime?
  deletedAt      DateTime?
  isDeleted      Boolean       @default(false)
  assignedUserId String?
  couponClaims   CouponClaim[]
  couponUsages   CouponUsage[]
  orders         Order[]
}

model CouponUsage {
  id       String   @id @default(uuid())
  couponId String
  userId   String
  orderId  String?
  usedAt   DateTime @default(now())
  coupon   Coupon   @relation(fields: [couponId], references: [id])
  order    Order?   @relation(fields: [orderId], references: [id])
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CouponClaim {
  id        String   @id @default(uuid())
  couponId  String
  userId    String
  claimedAt DateTime @default(now())
  coupon    Coupon   @relation(fields: [couponId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId])
  @@index([couponId])
  @@index([userId])
  @@index([claimedAt])
}

model ReferralCode {
  id        String     @id @default(uuid())
  code      String     @unique
  userId    String     @unique
  createdAt DateTime   @default(now())
  referrals Referral[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id              String           @id @default(uuid())
  referrerId      String
  referredId      String           @unique
  referralCodeId  String
  orderId         String?
  status          ReferralStatus   @default(PENDING_QUALIFICATION)
  qualifiedAt     DateTime?
  rewardedAt      DateTime?
  createdAt       DateTime         @default(now())
  order           Order?           @relation(fields: [orderId], references: [id])
  referralCode    ReferralCode     @relation(fields: [referralCodeId], references: [id])
  referred        User             @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)
  referrer        User             @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referralRewards ReferralReward[]

  @@unique([referrerId, referredId])
  @@index([referrerId])
  @@index([referredId])
  @@index([referralCodeId])
}

model ReferralReward {
  id            String               @id @default(uuid())
  referralId    String
  beneficiaryId String
  role          ReferralRewardRole
  amount        Int
  status        ReferralRewardStatus @default(PENDING)
  issuedAt      DateTime?
  transactionId String?
  beneficiary   User                 @relation("ReferralRewardBeneficiary", fields: [beneficiaryId], references: [id], onDelete: Cascade)
  referral      Referral             @relation(fields: [referralId], references: [id])
  transaction   Transaction?         @relation(fields: [transactionId], references: [id])

  @@unique([referralId, role])
  @@index([referralId])
  @@index([beneficiaryId])
  @@index([transactionId])
}

/// *
/// * ===========================
/// * STAFF PROFILES & VERIFICATION
/// * ===========================
model StaffProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  staffId   String  @unique
  firstName String
  lastName  String
  phone     String?

  stripeAccountId String? @unique

  isVerified         Boolean            @default(false)
  verifiedAt         DateTime?
  verificationMethod String?
  verificationStatus VerificationStatus @default(PENDING)

  department     String?
  employmentType EmploymentType?
  status         StaffStatus     @default(ACTIVE)

  joinedAt     DateTime  @default(now())
  lastActiveAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Verification {
  id     String             @id @default(cuid())
  userId String
  role   VerificationRole
  status VerificationStatus @default(PENDING)

  stripeVerificationId String?
  stripeAccountId      String?
  stripeSessionId      String?

  documentType String?

  rejectionReason String?

  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  verificationDocuments VerificationDocument[]

  @@index([userId])
  @@index([status])
}

model VerificationDocument {
  id             String  @id @default(cuid())
  userId         String
  verificationId String?

  type        DocumentType
  fileAssetId String
  fileAsset   FileAsset    @relation("VerificationDocumentAsset", fields: [fileAssetId], references: [id], onDelete: Restrict)

  fingerprint String? @unique

  status     VerificationStatus @default(PENDING)
  reviewedAt DateTime?

  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  verification Verification? @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([verificationId])
  @@index([fileAssetId])
}

/// *
/// * ===========================
/// * ADDRESS & SITE CONFIG
/// * ===========================
model Address {
  id         String       @id @default(cuid())
  userId     String
  fullName   String
  phone      String
  street     String
  city       String
  state      String?
  country    String
  postalCode String?
  latitude   Float?
  longitude  Float?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  isDefault  Boolean      @default(false)
  label      AddressLabel @default(HOME)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SiteConfiguration {
  id String @id @default(cuid())

  singleton Boolean @unique @default(true)

  siteName  String
  siteEmail String
  sitePhone String?

  facebookUrl   String?
  instagramUrl  String?
  twitterUrl    String?
  youtubeUrl    String?
  tiktokUrl     String?
  whatsappPhone String?

  supportEmail String?
  supportPhone String?

  seoTitle       String?
  seoDescription String?

  siteLogoFileAssetId String?

  platformCommissionRate    Float @default(0.10)
  foodMinimumDeliveryFee    Float @default(2)
  generalMinimumDeliveryFee Float @default(5)

  foodBaseDeliveryRate Float @default(1.5)
  foodRatePerMile      Float @default(0.7)

  generalBaseDeliveryRate Float @default(2)
  generalRatePerMile      Float @default(1)

  expressMultiplier Float @default(1.5)
  pickupFee         Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteLogoFileAsset FileAsset? @relation("SiteConfigurationLogoAsset", fields: [siteLogoFileAssetId], references: [id], onDelete: SetNull)

  @@index([siteLogoFileAssetId])
}

model UserPreference {
  id                   String   @id @default(cuid())
  userId               String   @unique
  currency             String   @default("USD")
  theme                String   @default("system")
  emailOrderUpdates    Boolean  @default(true)
  emailWalletAlerts    Boolean  @default(true)
  emailPromotions      Boolean  @default(false)
  emailRecommendations Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id      String  @id @default(cuid())
  userId  String
  title   String
  message String
  read    Boolean @default(false)

  link String?
  type String?

  key String? @unique

  metadata Json?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// *
/// * ===========================
/// *  MARKETING & ANALYTICS
/// * ===========================
model HeroBanner {
  id String @id @default(cuid())

  title    String?
  subtitle String?
  ctaText  String?
  ctaLink  String?

  backgroundImageFileAssetId String?
  productImageFileAssetId    String?

  lottieUrl String?

  position        Int     @default(0)
  isActive        Boolean @default(true)
  impressionCount Int     @default(0)
  clickCount      Int     @default(0)

  startsAt         DateTime?
  endsAt           DateTime?
  lastImpressionAt DateTime?
  lastClickAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deletedAt                DateTime?
  isDeleted                Boolean                @default(false)
  placement                BannerPlacement        @default(HOMEPAGE)
  backgroundImageFileAsset FileAsset?             @relation("HeroBannerBackgroundAsset", fields: [backgroundImageFileAssetId], references: [id], onDelete: SetNull)
  productImageFileAsset    FileAsset?             @relation("HeroBannerProductAsset", fields: [productImageFileAssetId], references: [id], onDelete: SetNull)
  dailyStats               HeroBannerDailyStats[]
  marketingCampaigns       MarketingCampaign[]

  @@index([placement])
  @@index([isActive])
  @@index([position])
  @@index([startsAt])
  @@index([endsAt])
  @@index([backgroundImageFileAssetId])
  @@index([productImageFileAssetId])
}

model HeroBannerDailyStats {
  id          String   @id @default(cuid())
  bannerId    String
  date        DateTime
  impressions Int      @default(0)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  banner HeroBanner @relation(fields: [bannerId], references: [id], onDelete: Cascade)

  @@unique([bannerId, date])
  @@index([bannerId])
  @@index([date])
}

model MarketingCampaign {
  id           String                  @id @default(cuid())
  name         String
  slug         String                  @unique
  description  String?
  status       MarketingCampaignStatus @default(DRAFT)
  themeKey     String?
  accentColor  String?
  notes        String?
  heroBannerId String?
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  heroBanner       HeroBanner?                @relation(fields: [heroBannerId], references: [id], onDelete: SetNull)
  featuredStores   FeaturedStorePlacement[]
  featuredProducts FeaturedProductPlacement[]

  @@index([status])
  @@index([heroBannerId])
  @@index([startsAt])
  @@index([endsAt])
}

model FeaturedStorePlacement {
  id         String                 @id @default(cuid())
  campaignId String
  storeId    String
  slot       MarketingPlacementSlot
  isEnabled  Boolean                @default(true)
  priority   Int                    @default(0)
  tagLabel   String?
  notes      String?
  startsAt   DateTime?
  endsAt     DateTime?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  campaign MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  store    Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([campaignId, storeId, slot])
  @@index([slot, isEnabled])
  @@index([campaignId, slot, isEnabled])
  @@index([storeId, slot, isEnabled])
  @@index([priority])
  @@index([startsAt])
  @@index([endsAt])
}

model FeaturedProductPlacement {
  id         String                 @id @default(cuid())
  campaignId String
  productId  String
  slot       MarketingPlacementSlot
  isEnabled  Boolean                @default(true)
  priority   Int                    @default(0)
  tagLabel   String?
  notes      String?
  startsAt   DateTime?
  endsAt     DateTime?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  campaign MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product  Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([campaignId, productId, slot])
  @@index([slot, isEnabled])
  @@index([campaignId, slot, isEnabled])
  @@index([productId, slot, isEnabled])
  @@index([priority])
  @@index([startsAt])
  @@index([endsAt])
}

model SellerDailyStats {
  id       String   @id @default(cuid())
  sellerId String
  date     DateTime

  revenue      Float
  orders       Int
  productsSold Int

  createdAt DateTime @default(now())

  @@unique([sellerId, date])
  @@index([sellerId])
  @@index([date])
}

/// *
/// * ===========================
/// * MODERATION & AI
/// * ===========================
model ModeratorIdentity {
  id          String                @id @default(cuid())
  type        ModeratorIdentityType
  userId      String?               @unique
  displayName String
  isActive    Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  user              User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  incidentsCreated  ModerationIncident[] @relation("IncidentActor")
  incidentsReviewed ModerationIncident[] @relation("IncidentReviewer")

  @@index([type])
}

model ModerationIncident {
  id String @id @default(cuid())

  targetType ModerationTargetType
  targetId   String

  subjectUserId       String?
  actorModeratorId    String?
  reviewerModeratorId String?

  decision   ModerationDecision
  severity   ModerationSeverity
  confidence Float?

  policyCode String?
  reason     String

  evidence Json?
  metadata Json?

  strikeWeight Int @default(0)

  reviewStatus ReviewStatus     @default(NOT_REQUIRED)
  status       ModerationStatus @default(OPEN)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  subjectUser       User?              @relation("ModerationSubjectUser", fields: [subjectUserId], references: [id], onDelete: SetNull)
  actorModerator    ModeratorIdentity? @relation("IncidentActor", fields: [actorModeratorId], references: [id], onDelete: SetNull)
  reviewerModerator ModeratorIdentity? @relation("IncidentReviewer", fields: [reviewerModeratorId], references: [id], onDelete: SetNull)

  linkedReports UserReport[]

  @@index([targetType, targetId])
  @@index([subjectUserId])
  @@index([actorModeratorId])
  @@index([reviewerModeratorId])
  @@index([status])
  @@index([reviewStatus])
  @@index([createdAt])
}

model UserStrikeSnapshot {
  id String @id @default(cuid())

  userId String

  totalStrikes Int
  riskScore    Int

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model UserReport {
  id String @id @default(cuid())

  reporterId String
  reporter   User   @relation("UserReportsSubmitted", fields: [reporterId], references: [id], onDelete: Cascade)

  targetType UserReportTargetType
  targetId   String

  reportedUserId String?
  reportedUser   User?   @relation("UserReportsAgainst", fields: [reportedUserId], references: [id], onDelete: SetNull)

  reason      UserReportReason
  description String?

  status UserReportStatus @default(OPEN)

  moderationIncidentId String?
  moderationIncident   ModerationIncident? @relation(fields: [moderationIncidentId], references: [id], onDelete: SetNull)

  reviewedById String?
  reviewedBy   User?   @relation("UserReportsReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([reporterId])
  @@index([reportedUserId])
  @@index([targetType, targetId])
  @@index([status])
  @@index([createdAt])
}

